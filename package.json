{
  "name": "lokaa-app",
  "version": "1.0.2",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:clean": "./scripts/dev-stability.sh",
    "dev:stable": "npm run dev:clean",
    "auth-server": "node auth-server.js",
    "dev:with-auth": "concurrently \"npm run auth-server\" \"npm run dev\"",
    "build": "vite build",
    "build:dev": "vite build --mode development",
    "lint": "eslint .",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:indexeddb": "vitest run src/utils/indexeddb",
    "test:indexeddb:watch": "vitest src/utils/indexeddb",
    "test:indexeddb:ui": "vitest --ui src/utils/indexeddb",
    "test:coverage": "vitest run --coverage",
    "test:indexeddb:coverage": "vitest run --coverage src/utils/indexeddb",
    "test:security": "vitest run src/__tests__/security",
    "test:security:watch": "vitest src/__tests__/security",
    "test:security:coverage": "vitest run --coverage src/__tests__/security",
    "ci:security": "vitest run --coverage --coverage.thresholds.lines=90 --coverage.thresholds.functions=90 --coverage.thresholds.branches=90 --coverage.thresholds.statements=90 src/__tests__/security",
    "check:coverage": "node scripts/checkCoverage.js",
    "check:validation": "vitest run --dir tests/validation"
  },
  "engines": {
    "node": ">=20.0.0"
  },
