  "scripts": {
    "dev": "vite",
    "dev:clean": "./scripts/dev-stability.sh",
    "dev:stable": "npm run dev:clean",
    "auth-server": "node auth-server.js",
    "dev:with-auth": "concurrently \"npm run auth-server\" \"npm run dev\"",
    "build": "vite build",
    "build:dev": "vite build --mode development",
    "lint": "eslint .",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:indexeddb": "vitest run src/utils/indexeddb",
    "test:indexeddb:watch": "vitest src/utils/indexeddb",
    "test:indexeddb:ui": "vitest --ui src/utils/indexeddb",
    "test:coverage": "vitest run --coverage",
    "test:indexeddb:coverage": "vitest run --coverage src/utils/indexeddb",
    "test:security": "jest --config jest.security.config.js",
    "test:security:watch": "jest --config jest.security.config.js --watch",
    "test:security:coverage": "jest --config jest.security.config.js --coverage",
    "ci:security": "jest --config jest.security.config.js --coverage --coverageThreshold='{\"global\":{\"branches\":90,\"functions\":90,\"lines\":90,\"statements\":90}}'",
    "check:coverage": "node scripts/checkCoverage.js",
    "check:validation": "vitest run --dir tests/validation"
  },
