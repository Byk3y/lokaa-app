## Common Patterns

### API Calls
```typescript
// Use custom hooks for API calls
const useLessonData = (lessonId: string) => {
  const [data, setData] = useState<Lesson | null>(null);
  const [loading, setLoading] = useState(true);
  const [error, setError] = useState<Error | null>(null);

  useEffect(() => {
    // Implementation
  }, [lessonId]);

  return { data, loading, error };
};
```

### Component Structure
```typescript
// Container component
export const LessonContainer = ({ lessonId }: Props) => {
  const { data, loading, error } = useLessonData(lessonId);
  
  if (loading) return <LoadingSpinner />;
  if (error) return <ErrorMessage error={error} />;
  
  return <LessonView lesson={data} />;
};

// UI component
export const LessonView = ({ lesson }: { lesson: Lesson }) => {
  return (
    <div className="lesson-container">
      {/* Implementation */}
    </div>
  );
};
```

### State Management
```typescript
// Zustand store pattern
interface LessonStore {
  lessons: Lesson[];
  currentLesson: Lesson | null;
  loading: boolean;
  fetchLesson: (id: string) => Promise<void>;
}

export const useLessonStore = create<LessonStore>((set, get) => ({
  lessons: [],
  currentLesson: null,
  loading: false,
  fetchLesson: async (id: string) => {
    set({ loading: true });
    try {
      const lesson = await api.getLesson(id);
      set({ currentLesson: lesson, loading: false });
    } catch (error) {
      set({ loading: false });
      throw error;
    }
  },
}));
```

